rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function memberPath() {
      return /databases/$(database)/documents/members/$(request.auth.uid);
    }

    function memberExists() {
      return signedIn() && exists(memberPath());
    }

    function me() {
      return get(memberPath()).data;
    }

    function active() {
      return memberExists() && me().status == 'active';
    }

    function roleIs(value) {
      return active() && me().role == value;
    }

    function admin() {
      return roleIs('admin');
    }

    function manager() {
      return roleIs('manager') || admin();
    }

    function captain() {
      return roleIs('captain');
    }

    function manageProducts() {
      return captain() || manager();
    }

    function approver() {
      return captain()
        || manager()
        || (active() && me().permissions.canApprove == true);
    }

    function canAssignApprovers() {
      return captain() || manager();
    }

    match /members/{uid} {
      allow get: if active() &&
        (request.auth.uid == uid || captain() || manager());

      allow list: if captain() || manager();

      allow create, delete: if false;

      allow update: if admin();

      allow update: if active()
        && request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'firstName',
          'lastName',
          'displayName',
          'position',
          'department',
          'phone',
          'photoURL',
          'profileUpdatedAt',
          'mustChangePassword',
          'passwordChangePending',
          'passwordChangeStartedAt',
          'passwordChangedAt',
          'lastLoginAt'
        ]);

      allow update: if canAssignApprovers()
        && resource.data.role == 'staff'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'permissions',
          'approvalAssignedBy',
          'approvalAssignedAt'
        ]);
    }

    match /theviewWorkspaces/main/products/{id} {
      allow read: if active();
      allow create, delete: if manageProducts();
      allow update: if manageProducts()
        || (active()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock','updatedAt'])
          && request.resource.data.stock is number
          && request.resource.data.stock >= 0);
    }

    match /theviewWorkspaces/main/approvals/{id} {
      allow create: if admin() || (active()
        && request.resource.data.submittedByUid == request.auth.uid
        && request.resource.data.status == 'pending');

      allow read: if approver()
        || (active() && resource.data.submittedByUid == request.auth.uid);

      allow update: if approver()
        || (
          active()
          && resource.data.submittedByUid == request.auth.uid
          && resource.data.status == 'pending'
          && request.resource.data.submittedByUid == resource.data.submittedByUid
          && request.resource.data.status == resource.data.status
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'qty',
            'type',
            'location',
            'updatedAt',
            'updatedByUid',
            'updatedByName'
          ])
        );

      allow delete: if approver()
        || (
          active()
          && resource.data.submittedByUid == request.auth.uid
          && resource.data.status == 'pending'
        );
    }

    match /theviewWorkspaces/main/logs/{id} {
      allow create: if active() && request.resource.data.actorUid == request.auth.uid;
      allow read: if active();

      allow update: if approver()
        || (
          active()
          && resource.data.actorUid == request.auth.uid
          && resource.data.action == 'ส่งตรวจ'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'action',
            'detail',
            'qty',
            'unit',
            'location',
            'moveType',
            'time',
            'updatedAt',
            'cancelledAt'
          ])
          && (
            request.resource.data.action == 'ส่งตรวจ'
            || request.resource.data.action == 'ยกเลิก'
          )
        );

      allow delete: if admin();
    }


    match /theviewWorkspaces/main/auditLogs/{id} {
      allow create: if active()
        && request.resource.data.actorUid == request.auth.uid
        && request.resource.data.immutable == true;
      allow read: if manageProducts();
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
