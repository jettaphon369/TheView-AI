rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn(){ return request.auth != null; }
    function memberPath(){ return /databases/$(database)/documents/members/$(request.auth.uid); }
    function memberExists(){ return signedIn() && exists(memberPath()); }
    function me(){ return get(memberPath()).data; }
    function active(){ return memberExists() && me().status == 'active'; }
    function roleIs(value){ return active() && me().role == value; }
    function admin(){ return roleIs('admin'); }
    function manager(){ return roleIs('manager') || admin(); }
    function captain(){ return roleIs('captain'); }
    function manageProducts(){ return captain() || manager(); }
    function approver(){
      return captain() || manager() ||
        (active() && me().permissions.canApprove == true);
    }
    function canAssignApprovers(){ return captain() || manager(); }

    match /members/{uid} {
      allow get: if active() && (request.auth.uid == uid || captain() || manager());
      allow list: if captain() || manager();
      allow create, delete: if false;

      // แอดมินแก้ข้อมูลสมาชิก ตำแหน่ง สถานะ และสิทธิ์ได้ทั้งหมด
      allow update: if admin();

      // สมาชิกแก้ข้อมูลส่วนตัวของตนเองเท่านั้น
      allow update: if active() && request.auth.uid == uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'firstName','lastName','displayName','position','department','phone',
          'profileUpdatedAt','mustChangePassword','passwordChangedAt','lastLoginAt'
        ]) &&
        request.resource.data.username == resource.data.username &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.status == resource.data.status &&
        request.resource.data.permissions == resource.data.permissions;

      // กัปตัน/ผู้จัดการเลือกผู้ช่วยอนุมัติได้เฉพาะสมาชิกตำแหน่งพนักงาน
      allow update: if canAssignApprovers() && resource.data.role == 'staff' &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.status == resource.data.status &&
        request.resource.data.username == resource.data.username &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'permissions','approvalAssignedBy','approvalAssignedAt'
        ]) &&
        request.resource.data.permissions.diff(resource.data.permissions).affectedKeys().hasOnly(['canApprove']);
    }

    match /theviewWorkspaces/main/products/{id} {
      allow read: if active();
      allow create, delete: if manageProducts();
      // สมาชิกทุกคนอัปเดตจำนวนสต๊อกได้จากรับเข้า/เบิกออก
      allow update: if active();
    }

    match /theviewWorkspaces/main/approvals/{id} {
      // พนักงานส่งเข้าคิวได้ แต่เห็นคิวเฉพาะผู้มีสิทธิ์อนุมัติ
      allow create: if active();
      allow read, update, delete: if approver();
    }

    match /theviewWorkspaces/main/logs/{id} {
      allow create: if active();
      allow read: if active();
      allow update: if approver();
      allow delete: if admin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
